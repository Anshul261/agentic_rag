# =============================================================================
# Agentic RAG - Frontend Dockerfile
# Security: Multi-stage build, non-root user, minimal image
# =============================================================================


# -----------------------------------------------------------------------------
# Stage 1: Builder - Install dependencies and build
# -----------------------------------------------------------------------------
FROM node:22-alpine AS builder

# Set working directory
WORKDIR /app

# Copy package files
COPY UI-Iluminati/package.json UI-Iluminati/package-lock.json* ./

# Install dependencies (dev needed for build)
RUN npm ci

# Copy source code
COPY UI-Iluminati/ .

# Build the application
RUN npm run build


# -----------------------------------------------------------------------------
# Stage 2: Runtime - Minimal production image
# -----------------------------------------------------------------------------
# Use Alpine for smallest base (~5MB)
FROM node:22-alpine AS runtime

# Security: Create non-root user
RUN addgroup -S appgroup -g 1001 && \
    adduser -S appuser -u 1001 -G appgroup

# Set working directory
WORKDIR /app

# Create production directory with proper ownership
RUN mkdir -p /app/.next/cache && \
    chown -R appuser:appgroup /app

# Copy built artifacts from builder
COPY --from=builder --chown=appuser:appgroup /app/.next ./next
COPY --from=builder --chown=appuser:appgroup /app/public ./public
COPY --from=builder --chown=appuser:appgroup /app/package.json ./
COPY --from=builder --chown=appuser:appgroup /app/node_modules ./node_modules

# Environment variables for production
ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1

# Expose port
EXPOSE 3000

# Switch to non-root user
USER appuser

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD wget --spider -q http://localhost:3000/health || exit 1

# Run the application (use start script from package.json)
CMD ["npm", "start"]