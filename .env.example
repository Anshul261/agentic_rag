# =============================================================================
# Agentic RAG - Environment Template
# Copy this to .env and fill in your values
# NEVER commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL + PgVector)
# NOTE: Use 'postgres' as hostname when running via docker-compose
# -----------------------------------------------------------------------------
POSTGRES_USER=ai
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=ai
# Connection URL (used by backend)
# Format: postgresql+psycopg://user:password@hostname:port/dbname
# Note: pgvector runs on internal port 5432, exposed as 5433 in docker-compose
PGVECTOR_DB_URL=postgresql+psycopg://ai:change_me_in_production@postgres:5432/ai

# -----------------------------------------------------------------------------
# Azure OpenAI
# -----------------------------------------------------------------------------
AZURE_OPENAI_API_KEY=your_azure_api_key_here
AZURE_OPENAI_ENDPOINT_5=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME_5=gpt-5
OPENAI_API_VERSION=2024-02-15-preview

# -----------------------------------------------------------------------------
# HuggingFace (for embeddings)
# -----------------------------------------------------------------------------
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# -----------------------------------------------------------------------------
# JWT Secret (CRITICAL - change in production!)
# Use a strong secret (at least 32 characters)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
SECRET_KEY=change_me_use_strong_random_secret_min_32_chars

# -----------------------------------------------------------------------------
# OpenSandbox (Python code execution)
# -----------------------------------------------------------------------------
SANDBOX_API_KEY=  # Set if you enabled auth in ~/.sandbox.toml

# -----------------------------------------------------------------------------
# Optional: Brave Search
# -----------------------------------------------------------------------------
# BRAVE_API_KEY=

# -----------------------------------------------------------------------------
# Ollama (optional - for local embeddings, not currently used)
# -----------------------------------------------------------------------------
# OLLAMA_HOST=http://localhost:11434
# EMBEDDING_MODEL=nomic-embed-text-v2-moe
# EMBEDDING_DIMENSIONS=768